{
    "manifest_version": 3,
    "name": "Follow-Up Ticker",
    "version": "1.0",
    "description": "Never drop a client commitment. Log follow-ups in 5 seconds, see overdue count on the icon.",
    "permissions": ["storage"],
    "action": {
      "default_popup": "popup.html",
      "default_icon": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
      }
    },
    "background": {
      "service_worker": "background.js"
    },
    "icons": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }